<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled: this tool reads photos from arbitrary volumes
	     (memory cards), writes to user-chosen folders, and spawns
	     ffmpeg/sips. Not intended for Mac App Store distribution. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
